DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-random-string-at-least-32-characters-long"
PORT=4000

# Production: set to false after creating your user (see README — Private deployment)
# NODE_ENV=production also requires JWT_SECRET (32+ chars) and ALLOW_REGISTER=false
ALLOW_REGISTER=true

# Optional production hardening (see README — Private deployment)
# CORS_ORIGIN=https://your-domain.example
# JSON_BODY_LIMIT=1mb

# Required for market EOD prices (Twelve Data provider)
MARKET_DATA_API_KEY="your_twelve_data_api_key"
MARKET_BACKFILL_DAYS=90

# Optional backup script (npm run db:backup)
# BACKUP_DIR=backups
# BACKUP_GZIP=true
