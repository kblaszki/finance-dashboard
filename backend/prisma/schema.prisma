// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  passwordHash         String
  createdAt            DateTime              @default(now())
  transactions         Transaction[]
  portfolioTrades      PortfolioTrade[]
  accounts             Account[]
  financialAccounts    FinancialAccount[]
  categories           Category[]
}

model FinancialAccount {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String
  name            String
  currency        String
  openingBalance  Decimal  @default(0)
  manualValue     Decimal?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  legacyTransactions Transaction[]
  bondHoldings       BondHolding[]

  @@unique([userId, name])
  @@index([userId, type])
}

model Category {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  name      String
  kind      String

  transactions Transaction[]

  @@unique([userId, parentId, name, kind])
  @@index([userId, kind])
}

model BondHolding {
  id           Int              @id @default(autoincrement())
  accountId    Int
  account      FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  series       String
  nominal      Decimal
  purchaseDate DateTime
  currency     String
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([accountId])
}

model Account {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  name      String
  currency  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankDetails      BankAccountDetails?
  brokerageDetails BrokerageAccountDetails?
  balanceDaily     AccountBalanceDaily[]
  transactions     Transaction[]
  trades           PortfolioTrade[]

  @@unique([userId, name])
  @@index([userId, type])
}

model BankAccountDetails {
  accountId      Int     @id
  account        Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  openingBalance Decimal @default(0)
}

model BrokerageAccountDetails {
  accountId    Int     @id
  account      Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  baseCurrency String
  cashBalance  Decimal @default(0)
}

model AccountBalanceDaily {
  id                   Int      @id @default(autoincrement())
  accountId            Int
  account              Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  balanceDate          DateTime
  balance              Decimal
  cashComponent        Decimal?
  securitiesComponent  Decimal?
  currency             String

  @@unique([accountId, balanceDate])
  @@index([accountId, balanceDate])
}

model Asset {
  id        Int      @id @default(autoincrement())
  symbol    String
  name      String?
  assetType String   @default("STOCK")
  currency  String
  exchange  String?
  source    String   @default("twelve_data")
  createdAt DateTime @default(now())

  prices MarketPriceDaily[]
  trades PortfolioTrade[]

  @@unique([symbol, exchange, source])
  @@index([symbol])
}

model MarketPriceDaily {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  close     Decimal
  priceDate DateTime
  fetchedAt DateTime @default(now())
  source    String

  @@unique([assetId, priceDate, source])
  @@index([assetId, priceDate])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amount      Decimal
  currency    String
  category    String
  categoryId  Int?
  categoryRef Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date        DateTime
  description String?
  accountId   Int?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  legacyFinancialAccountId Int?
  legacyFinancialAccount   FinancialAccount? @relation(fields: [legacyFinancialAccountId], references: [id], onDelete: SetNull)
  importHash  String?

  @@unique([userId, importHash])
  @@index([userId, accountId])
  @@index([userId, categoryId])
  @@index([userId, legacyFinancialAccountId])
}

model PortfolioTrade {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  side       String   @default("BUY")
  symbol     String
  quantity   Decimal
  tradePrice Decimal
  tradeDate  DateTime
  currency   String
  category   String
  createdAt  DateTime @default(now())
  accountId  Int
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetId    Int?
  asset      Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId, accountId, symbol])
  @@index([assetId])
}
