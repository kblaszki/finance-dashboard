generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  accounts     Account[]
}

model Account {
  id                     Int                      @id @default(autoincrement())
  userId                 Int
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountType            String
  name                   String
  currency               String
  cashBalance            Decimal                  @default(0)
  openingBalance         Decimal                  @default(0)
  description            String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  transactions           Transaction[]
  holdingLots            HoldingLot[]
  valuationsDaily        AccountValuationDaily[]
  holdingValuationsDaily HoldingValuationDaily[]

  @@unique([userId, name])
  @@index([userId, accountType])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  accountId       Int
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactionType String
  amount          Decimal
  balanceAfter    Decimal
  currency        String
  category        String
  date            DateTime
  description     String?

  @@index([accountId, date])
}

model Instrument {
  id                     Int                      @id @default(autoincrement())
  instrumentType         String
  symbol                 String
  name                   String?
  exchange               String?
  currency               String
  source                 String                   @default("manual")
  createdAt              DateTime                 @default(now())
  holdingLots            HoldingLot[]
  valuations             InstrumentValuation[]
  holdingValuationsDaily HoldingValuationDaily[]

  @@unique([symbol, exchange, source])
  @@index([symbol])
}

model HoldingLot {
  id            Int        @id @default(autoincrement())
  accountId     Int
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  side          String
  quantity      Decimal
  quantityAfter Decimal
  totalPrice    Decimal?
  pricePerUnit  Decimal?
  currency      String
  tradeDate     DateTime
  createdAt     DateTime   @default(now())

  @@index([accountId, instrumentId, tradeDate])
}

model InstrumentValuation {
  id            Int        @id @default(autoincrement())
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  valuationDate DateTime
  price         Decimal
  currency      String
  source        String
  fetchedAt     DateTime   @default(now())

  @@unique([instrumentId, valuationDate, source])
  @@index([instrumentId, valuationDate])
}

model AccountValuationDaily {
  id              Int      @id @default(autoincrement())
  accountId       Int
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  valuationDate   DateTime
  totalValue      Decimal
  cashValue       Decimal
  securitiesValue Decimal
  currency        String

  @@unique([accountId, valuationDate])
  @@index([accountId, valuationDate])
}

model HoldingValuationDaily {
  id            Int        @id @default(autoincrement())
  accountId     Int
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  valuationDate DateTime
  quantity      Decimal
  marketValue   Decimal
  currency      String

  @@unique([accountId, instrumentId, valuationDate])
  @@index([accountId, instrumentId, valuationDate])
}
