generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  username     String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  accounts     Account[]
  categories   Category[]
  incomeEvents     IncomeEvent[]
  liabilities      Liability[]
  propertyCashFlows PropertyCashFlow[]
  taxWrapperWithdrawals TaxWrapperWithdrawal[]
  ikzeContributions IkzeContribution[]
  positionTransfers PositionTransfer[]
  corporateActions CorporateAction[]
  taxLossCarryforwards TaxLossCarryforward[]
  taxReportSnapshots TaxReportSnapshot[]
  taxChecklistItems TaxChecklistItem[]
  propertySales PropertySale[]
  documentAttachments DocumentAttachment[]
  importPresets ImportPreset[]
  assetValuations AssetValuation[]
  couponSchedules CouponSchedule[]
}

model Account {
  id                     Int                      @id @default(autoincrement())
  userId                 Int
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountType            String
  name                   String
  currency               String
  cashBalance            Decimal                  @default(0)
  openingBalance         Decimal                  @default(0)
  openingCashAsOf        DateTime?
  metalGrams             Decimal?
  taxWrapperType         String                   @default("standard")
  rentalTaxMethod        String?
  description            String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  transactions           Transaction[]
  holdings               Holding[]
  valuationsDaily        AccountValuationDaily[]
  holdingValuationsDaily HoldingValuationDaily[]
  importBatches          ImportBatch[]
  incomeEvents           IncomeEvent[]
  liabilities            Liability[]
  propertyCashFlows      PropertyCashFlow[]
  taxWrapperWithdrawals  TaxWrapperWithdrawal[]
  ikzeContributions      IkzeContribution[]
  positionTransfersFrom  PositionTransfer[]     @relation("PositionTransferFrom")
  positionTransfersTo    PositionTransfer[]     @relation("PositionTransferTo")
  corporateActions       CorporateAction[]
  propertySales          PropertySale[]
  assetValuations        AssetValuation[]
  couponSchedules        CouponSchedule[]

  @@unique([userId, name])
  @@index([userId, accountType])
}

model Transaction {
  id              Int                 @id @default(autoincrement())
  accountId       Int
  account         Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactionType String
  amount          Decimal
  balanceAfter    Decimal
  currency        String
  category        String
  categoryId      Int?
  categoryRef     Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date            DateTime
  description     String?
  splits          TransactionSplit[]

  @@index([accountId, date])
  @@index([categoryId])
}

model Category {
  id           Int                @id @default(autoincrement())
  userId       Int
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  parentId     Int?
  parent       Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]         @relation("CategoryHierarchy")
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  budgets      Budget[]
  transactions Transaction[]
  splits       TransactionSplit[]

  @@index([userId])
  @@index([userId, parentId])
}

model Budget {
  id          Int      @id @default(autoincrement())
  userId      Int
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  budgetMonth DateTime
  amount      Decimal
  currency    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, budgetMonth])
  @@index([userId, budgetMonth])
}

model TransactionSplit {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    Int
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount        Decimal

  @@unique([transactionId, categoryId])
}

model IncomeEvent {
  id             Int         @id @default(autoincrement())
  userId         Int
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      Int
  account        Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId   Int?
  instrument     Instrument? @relation(fields: [instrumentId], references: [id], onDelete: SetNull)
  eventType      String
  taxType        String?
  amount         Decimal
  currency       String
  occurredOn     DateTime
  description    String?
  withheldTax    Decimal     @default(0)
  sourceCountry  String?
  foreignTaxPaid Decimal     @default(0)
  createdAt      DateTime    @default(now())
  couponSchedule CouponSchedule?

  @@index([userId, occurredOn])
  @@index([accountId, occurredOn])
}

model TaxWrapperWithdrawal {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  withdrawnOn    DateTime
  amount         Decimal
  currency       String
  withdrawalType String
  includeInPit38 Boolean  @default(true)
  description    String?
  createdAt      DateTime @default(now())

  @@index([userId, withdrawnOn])
  @@index([accountId, withdrawnOn])
}

model IkzeContribution {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     Int
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taxYear       Int
  amount        Decimal
  currency      String
  contributedOn DateTime
  createdAt     DateTime @default(now())

  @@index([userId, taxYear])
  @@index([accountId, taxYear])
}

model CorporateAction {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    Int
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  holdingId    Int?
  holding      Holding?   @relation(fields: [holdingId], references: [id], onDelete: SetNull)
  instrumentId Int
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  actionType   String
  actionDate   DateTime
  ratio        Decimal?
  quantityDelta Decimal?
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([userId, actionDate])
  @@index([accountId, actionDate])
}

model PositionTransfer {
  id            Int        @id @default(autoincrement())
  userId        Int
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccountId Int
  fromAccount   Account    @relation("PositionTransferFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId   Int
  toAccount     Account    @relation("PositionTransferTo", fields: [toAccountId], references: [id], onDelete: Cascade)
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  quantity      Decimal
  transferDate  DateTime
  createdAt     DateTime   @default(now())

  @@index([userId, transferDate])
  @@index([fromAccountId, transferDate])
  @@index([toAccountId, transferDate])
}

model Liability {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     Int?
  account       Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  name          String
  liabilityType String
  balance       Decimal
  currency      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model PropertyCashFlow {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  flowType    String
  amount      Decimal
  currency    String
  occurredOn  DateTime
  description String?
  createdAt   DateTime @default(now())

  @@index([userId, occurredOn])
  @@index([accountId, occurredOn])
}

model TaxLossCarryforward {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear    Int
  lossAmount Decimal
  usedAmount Decimal  @default(0)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, taxYear])
  @@index([userId, taxYear])
}

model TaxReportSnapshot {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear       Int
  computedAt    DateTime  @default(now())
  payload       String
  invalidatedAt DateTime?

  @@index([userId, taxYear])
}

model TaxChecklistItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear     Int
  itemKey     String
  completedAt DateTime @default(now())

  @@unique([userId, taxYear, itemKey])
  @@index([userId, taxYear])
}

model PropertySale {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId         Int
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  soldOn            DateTime
  proceeds          Decimal
  acquisitionCost   Decimal
  improvementsCost  Decimal  @default(0)
  fiveYearExemption Boolean  @default(false)
  currency          String
  description       String?
  createdAt         DateTime @default(now())

  @@index([userId, soldOn])
  @@index([accountId, soldOn])
}

model DocumentAttachment {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    Int
  filename    String
  mimeType    String?
  storageRef  String?
  description String?
  uploadedAt  DateTime @default(now())

  @@index([userId, entityType, entityId])
}

model ImportPreset {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  broker        String
  targetType    String
  columnMapping String
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Instrument {
  id                     Int                      @id @default(autoincrement())
  instrumentType         String
  symbol                 String
  name                   String?
  exchange               String?
  currency               String
  pitZgCountry           String                   @default("PL")
  source                 String                   @default("manual")
  createdAt              DateTime                 @default(now())
  holdings               Holding[]
  valuations             InstrumentValuation[]
  holdingValuationsDaily HoldingValuationDaily[]
  incomeEvents           IncomeEvent[]
  corporateActions       CorporateAction[]
  positionTransfers      PositionTransfer[]
  assetValuations        AssetValuation[]
  couponSchedules        CouponSchedule[]

  @@unique([symbol, exchange, source])
  @@index([symbol])
}

model Holding {
  id           Int         @id @default(autoincrement())
  accountId    Int
  account      Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId Int
  instrument   Instrument  @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  quantity     Decimal     @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lots         HoldingLot[]
  corporateActions CorporateAction[]

  @@unique([accountId, instrumentId])
  @@index([accountId])
}

model HoldingLot {
  id            Int     @id @default(autoincrement())
  holdingId     Int
  holding       Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  side          String
  quantity      Decimal
  quantityAfter Decimal
  totalPrice    Decimal?
  commission    Decimal                  @default(0)
  pricePerUnit  Decimal?
  currency      String
  tradeDate      DateTime
  settlementDate DateTime?
  createdAt      DateTime @default(now())

  @@index([holdingId, tradeDate])
}

model InstrumentValuation {
  id            Int        @id @default(autoincrement())
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  valuationDate DateTime
  price         Decimal
  currency      String
  source        String
  fetchedAt     DateTime   @default(now())

  @@unique([instrumentId, valuationDate, source])
  @@index([instrumentId, valuationDate])
}

model FxRateDaily {
  id            Int      @id @default(autoincrement())
  rateDate      DateTime
  baseCurrency  String
  quoteCurrency String
  rate          Decimal
  source        String   @default("nbp")

  @@unique([rateDate, baseCurrency, quoteCurrency, source])
  @@index([rateDate, baseCurrency, quoteCurrency])
}

model AccountValuationDaily {
  id              Int      @id @default(autoincrement())
  accountId       Int
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  valuationDate   DateTime
  totalValue      Decimal
  cashValue       Decimal
  securitiesValue Decimal
  currency        String

  @@unique([accountId, valuationDate])
  @@index([accountId, valuationDate])
}

model HoldingValuationDaily {
  id            Int        @id @default(autoincrement())
  accountId     Int
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  Int
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  valuationDate DateTime
  quantity      Decimal
  marketValue   Decimal
  currency      String

  @@unique([accountId, instrumentId, valuationDate])
  @@index([accountId, instrumentId, valuationDate])
}

model ImportBatch {
  id         Int         @id @default(autoincrement())
  accountId  Int
  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  broker     String
  filename   String?
  importedAt DateTime    @default(now())
  rows       ImportRow[]

  @@index([accountId, importedAt])
}

model ImportRow {
  id            Int         @id @default(autoincrement())
  batchId       Int
  batch         ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  accountId     Int
  externalHash  String
  holdingLotId  Int?
  transactionId Int?

  @@unique([accountId, externalHash])
  @@index([batchId])
}

model AssetValuation {
  id           Int         @id @default(autoincrement())
  userId       Int
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    Int?
  account      Account?    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId Int?
  instrument   Instrument? @relation(fields: [instrumentId], references: [id], onDelete: SetNull)
  valuedOn     DateTime
  value        Decimal
  currency     String
  source       String      @default("manual")
  description  String?
  createdAt    DateTime    @default(now())

  @@index([userId, accountId, valuedOn])
  @@index([userId, instrumentId, valuedOn])
}

model CouponSchedule {
  id            Int          @id @default(autoincrement())
  userId        Int
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     Int
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  Int
  instrument    Instrument   @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  scheduleType  String
  paymentOn     DateTime
  amount        Decimal
  currency      String
  description   String?
  incomeEventId Int?         @unique
  incomeEvent   IncomeEvent? @relation(fields: [incomeEventId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([userId, paymentOn])
  @@index([accountId, instrumentId])
}
