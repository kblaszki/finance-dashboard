// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  passwordHash         String
  createdAt            DateTime              @default(now())
  transactions         Transaction[]
  portfolioPositions   PortfolioPosition[]
  portfolioTrades      PortfolioTrade[]
  investmentPortfolios InvestmentPortfolio[]
  budgets              Budget[]
  financialAccounts    FinancialAccount[]
  categories           Category[]
}

model FinancialAccount {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String
  name            String
  currency        String
  openingBalance  Decimal  @default(0)
  manualValue     Decimal?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions Transaction[]
  bondHoldings BondHolding[]

  @@unique([userId, name])
  @@index([userId, type])
}

model Category {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  name      String
  kind      String

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, parentId, name, kind])
  @@index([userId, kind])
}

model BondHolding {
  id           Int              @id @default(autoincrement())
  accountId    Int
  account      FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  series       String
  nominal      Decimal
  purchaseDate DateTime
  currency     String
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([accountId])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amount      Decimal
  currency    String
  category    String
  categoryId  Int?
  categoryRef Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date        DateTime
  description String?
  portfolioId Int?
  portfolio   InvestmentPortfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  accountId   Int?
  account     FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, portfolioId])
  @@index([userId, accountId])
  @@index([userId, categoryId])
}

model PortfolioPosition {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  quantity     Decimal
  buyPrice     Decimal
  currentPrice Decimal
  currency     String
  category     String
}

model PortfolioTrade {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  side      String   @default("BUY")
  symbol    String
  quantity  Decimal
  tradePrice Decimal
  tradeDate DateTime
  currency  String
  category  String
  createdAt DateTime @default(now())
  portfolioId Int
  portfolio InvestmentPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([userId, portfolioId, symbol])
}

model InvestmentPortfolio {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  baseCurrency String
  cashBalance  Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trades       PortfolioTrade[]
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId, baseCurrency])
}

model Budget {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearMonth   String
  category    String?
  categoryId  Int?
  categoryRef Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  limitAmount Decimal
  currency    String

  @@unique([userId, yearMonth, category])
  @@index([userId, categoryId])
}

model MarketPriceSnapshot {
  id         Int      @id @default(autoincrement())
  symbol     String
  exchange   String?
  currency   String
  close      Decimal
  priceDate  DateTime
  fetchedAt  DateTime @default(now())
  source     String

  @@index([symbol, priceDate])
  @@unique([symbol, priceDate, source])
}

model MarketPriceHistory {
  id        Int      @id @default(autoincrement())
  symbol    String
  exchange  String?
  currency  String
  close     Decimal
  priceDate DateTime
  fetchedAt DateTime @default(now())
  source    String

  @@index([symbol, priceDate])
  @@unique([symbol, priceDate, source])
}
